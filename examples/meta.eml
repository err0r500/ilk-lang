// THIS IS THE META SCHEMA

@assoc [tag]
Event {* _ Type} & {timestamp Int}

Tag {1 _ Type} | String

QueryItem {
    @constraint forall(tags, t => forall(eventTypes, e => e.assoc(t)))

    eventTypes []Event
    tags []Tag
}

Command {
    fields {* _ Type}

    @source [fields]
    emits []Event

    @source [fields] //for [tags]
    query []QueryItem
}
