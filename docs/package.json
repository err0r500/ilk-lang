{
  "name": "ilk-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "cd .. && wasm-pack build --target web --out-dir docs/public/wasm --no-default-features --features wasm",
    "prebuild": "npm run build:wasm && cp ../spec.md ./ilk-spec.md",
    "predev": "npm run build:wasm && cp ../spec.md ./ilk-spec.md",
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview"
  },
  "devDependencies": {
    "vitepress": "^1.6.3"
  }
}
